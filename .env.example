# Environment Configuration Example
# Copy this file to .env and update with your values

# Google TV Configuration
TV_IP=TV_IP_ADDRESS_HERE
TV_PORT=TV_PORT_HERE

# Timezone (e.g., America/New_York, Europe/London, Asia/Kolkata)
TZ=TIMEZONE_HERE

# API Configuration
API_HOST=0.0.0.0
API_PORT=API_PORT_HERE

# Security
# Set a strong password for API access
API_PASSWORD=your_secure_password_here

# Logging
# Logtail source token (optional, for remote logging)
LOGTAIL_TOKEN=LOGTAIL_TOKEN_HERE

# Database
DB_PATH=DB_PATH_HERE
